{
  "info": {
    "name": "TiendaLibros DSY2205",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUsuarios", "value": "http://localhost:8081" },
    { "key": "baseLibros", "value": "http://localhost:8082" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth — Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@tienda.cl\",\n  \"password\": \"password\"\n}"
        },
        "url": "{{baseUsuarios}}/api/auth/login"
      }
    },
    {
      "name": "Auth — Login cliente",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cliente1@mail.cl\",\n  \"password\": \"password\"\n}"
        },
        "url": "{{baseUsuarios}}/api/auth/login"
      }
    },
    {
      "name": "Usuarios — Listar (ADMIN)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUsuarios}}/api/users"
      }
    },
    {
      "name": "Usuarios — Crear (ADMIN)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"nuevo@mail.cl\",\n  \"password\": \"password123\",\n  \"nombre\": \"Test\",\n  \"apellido\": \"Usuario\",\n  \"activo\": true,\n  \"rolNombre\": \"CLIENTE\"\n}"
        },
        "url": "{{baseUsuarios}}/api/users"
      }
    },
    {
      "name": "Libros — Listar catálogo (público)",
      "request": {
        "method": "GET",
        "url": "{{baseLibros}}/api/libros"
      }
    },
    {
      "name": "Libros — Búsqueda q=orwell",
      "request": {
        "method": "GET",
        "url": "{{baseLibros}}/api/libros?q=orwell"
      }
    },
    {
      "name": "Libros — Crear (ADMIN + token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Libro de prueba\",\n  \"autor\": \"Autor QA\",\n  \"isbn\": \"978-0000000000\",\n  \"editorial\": \"Duoc\",\n  \"precio\": 5000,\n  \"stock\": 10,\n  \"activo\": true,\n  \"descripcion\": \"Demo Postman\"\n}"
        },
        "url": "{{baseLibros}}/api/libros"
      }
    },
    {
      "name": "Pedidos — Crear (CLIENTE + token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lineas\": [\n    { \"libroId\": 1, \"cantidad\": 1 }\n  ]\n}"
        },
        "url": "{{baseLibros}}/api/pedidos"
      }
    },
    {
      "name": "Pedidos — Listar",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseLibros}}/api/pedidos"
      }
    }
  ]
}
