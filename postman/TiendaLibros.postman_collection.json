{
  "info": {
    "name": "TiendaLibros DSY2205",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUsuarios", "value": "http://localhost:8081" },
    { "key": "baseLibros", "value": "http://localhost:8082" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "2" },
    { "key": "libroId", "value": "1" },
    { "key": "pedidoId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tienda.cl\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{baseUsuarios}}/api/auth/login"
          }
        },
        {
          "name": "Login cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente1@mail.cl\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{baseUsuarios}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Usuarios (8081)",
      "item": [
        {
          "name": "Listar (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUsuarios}}/api/users"
          }
        },
        {
          "name": "Obtener por id (ADMIN o propio usuario)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUsuarios}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Crear (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@mail.cl\",\n  \"password\": \"password123\",\n  \"nombre\": \"Test\",\n  \"apellido\": \"Usuario\",\n  \"activo\": true,\n  \"rolNombre\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUsuarios}}/api/users"
          }
        },
        {
          "name": "Actualizar (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente2@mail.cl\",\n  \"password\": null,\n  \"nombre\": \"Maria\",\n  \"apellido\": \"Lopez\",\n  \"activo\": true,\n  \"rolNombre\": \"CLIENTE\"\n}"
            },
            "url": "{{baseUsuarios}}/api/users/3"
          }
        },
        {
          "name": "Eliminar (ADMIN, no el propio usuario)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUsuarios}}/api/users/3"
          }
        }
      ]
    },
    {
      "name": "Libros (8082)",
      "item": [
        {
          "name": "Listar catálogo (público)",
          "request": {
            "method": "GET",
            "url": "{{baseLibros}}/api/libros"
          }
        },
        {
          "name": "Búsqueda q=orwell",
          "request": {
            "method": "GET",
            "url": "{{baseLibros}}/api/libros?q=orwell"
          }
        },
        {
          "name": "Obtener por id (público)",
          "request": {
            "method": "GET",
            "url": "{{baseLibros}}/api/libros/{{libroId}}"
          }
        },
        {
          "name": "Crear (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Libro de prueba\",\n  \"autor\": \"Autor QA\",\n  \"isbn\": \"978-0000000000\",\n  \"editorial\": \"Duoc\",\n  \"precio\": 5000,\n  \"stock\": 10,\n  \"activo\": true,\n  \"descripcion\": \"Demo Postman\"\n}"
            },
            "url": "{{baseLibros}}/api/libros"
          }
        },
        {
          "name": "Actualizar (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"1984\",\n  \"autor\": \"George Orwell\",\n  \"isbn\": \"978-8499890944\",\n  \"editorial\": \"Debolsillo\",\n  \"precio\": 9990,\n  \"stock\": 40,\n  \"activo\": true,\n  \"descripcion\": \"Distopia politica clasica.\"\n}"
            },
            "url": "{{baseLibros}}/api/libros/{{libroId}}"
          }
        },
        {
          "name": "Eliminar (ADMIN, ajustar libroId)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseLibros}}/api/libros/{{libroId}}"
          }
        }
      ]
    },
    {
      "name": "Pedidos (8082)",
      "item": [
        {
          "name": "Crear (CLIENTE o ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lineas\": [\n    { \"libroId\": 1, \"cantidad\": 1 }\n  ]\n}"
            },
            "url": "{{baseLibros}}/api/pedidos"
          }
        },
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseLibros}}/api/pedidos"
          }
        },
        {
          "name": "Obtener por id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseLibros}}/api/pedidos/{{pedidoId}}"
          }
        },
        {
          "name": "Cancelar (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseLibros}}/api/pedidos/{{pedidoId}}/cancelar"
          }
        },
        {
          "name": "Eliminar (solo ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseLibros}}/api/pedidos/{{pedidoId}}"
          }
        }
      ]
    }
  ]
}
